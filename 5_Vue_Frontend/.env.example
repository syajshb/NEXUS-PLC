# Origin of the Java (or other) backend for Vite dev proxy only.
# Example: http://localhost:8080 or http://192.168.1.100:8080
VITE_BACKEND_ORIGIN=http://localhost:8080

# Base path the browser uses for API calls.
# Dev (Vite proxy): /api  →  proxied to VITE_BACKEND_ORIGIN
# Prod (direct to backend): http://localhost:8080/api
VITE_API_BASE_URL=/api

# Dashboard auto-refresh interval for /api/plc-data/latest (milliseconds)
VITE_DASH_REFRESH_MS=8000
